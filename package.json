{
  "name": "@guy2co/yad2-mcp",
  "version": "1.0.17",
  "description": "MCP server for searching yad2.co.il real estate listings",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Guy2co/yad2-mcp.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run --exclude src/__tests__/e2e.test.ts",
    "test:watch": "vitest --exclude src/__tests__/e2e.test.ts",
    "test:coverage": "vitest run --coverage --exclude src/__tests__/e2e.test.ts",
    "test:e2e": "vitest run src/__tests__/e2e.test.ts",
    "knip": "knip",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "playwright": "^1.40.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "knip": "^5.86.0",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
